{
  "name": "maplibre-gl-components",
  "version": "0.17.2",
  "description": "Legend, colorbar, and HTML control components for MapLibre GL JS maps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/types/react.d.ts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/types/react.d.ts",
        "default": "./dist/react.cjs"
      }
    },
    "./style.css": "./dist/maplibre-gl-components.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:examples": "vite build --config vite.examples.config.ts",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "maplibre",
    "maplibre-gl",
    "legend",
    "colorbar",
    "colormap",
    "visualization",
    "map",
    "plugin",
    "control",
    "react",
    "typescript"
  ],
  "author": "Qiusheng Wu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opengeos/maplibre-gl-components.git"
  },
  "homepage": "https://github.com/opengeos/maplibre-gl-components",
  "bugs": {
    "url": "https://github.com/opengeos/maplibre-gl-components/issues"
  },
  "peerDependencies": {
    "@carbonplan/zarr-layer": ">=0.5.0",
    "@deck.gl/core": ">=9.3.2",
    "@deck.gl/geo-layers": ">=9.3.2",
    "@deck.gl/mapbox": ">=9.3.2",
    "@deck.gl/mesh-layers": ">=9.3.2",
    "@developmentseed/deck.gl-geotiff": ">=0.7.0",
    "@dvt3d/maplibre-three-plugin": ">=1.6.0",
    "jspdf": ">=4.2.1",
    "maplibre-gl": ">=5.24.0",
    "react": ">=19.2.6",
    "react-dom": ">=19.2.6",
    "three": ">=0.178.0"
  },
  "peerDependenciesMeta": {
    "@carbonplan/zarr-layer": {
      "optional": true
    },
    "@deck.gl/core": {
      "optional": true
    },
    "@deck.gl/geo-layers": {
      "optional": true
    },
    "@deck.gl/mapbox": {
      "optional": true
    },
    "@deck.gl/mesh-layers": {
      "optional": true
    },
    "@developmentseed/deck.gl-geotiff": {
      "optional": true
    },
